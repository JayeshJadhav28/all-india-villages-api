{
    "name": "allindia-villages-backend",
    "version": "1.0.0",
    "private": true,
    "description": "Backend API for All India Villages SaaS platform",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "start:prod": "npm run prisma:migrate:deploy && node dist/server.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "seed": "tsx prisma/seed.ts",
        "test": "vitest",
        "test:watch": "vitest --watch"
    },
    "dependencies": {
        "@prisma/client": "^5.19.0",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "helmet": "^7.1.0",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "node-cron": "^4.2.1",
        "uuid": "^10.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^20.14.10",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^10.0.0",
        "ioredis-mock": "^8.13.1",
        "prisma": "^5.19.0",
        "supertest": "^7.2.2",
        "tsx": "^4.21.0",
        "typescript": "^5.5.3",
        "vitest": "^4.1.4"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [],
    "author": "",
    "license": "ISC"
}
